# ──────────────────────────────────────────
# AdBot 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 저장 후 값 입력
# cp .env.example .env
# ──────────────────────────────────────────

# ── Claude API ──────────────────────────
# https://console.anthropic.com/ 에서 발급
CLAUDE_API_KEY=sk-ant-api03-여기에붙여넣기

# ── Blogger 설정 ────────────────────────
# Blogger 블로그 ID (URL에서 확인: blogspot.com/b/... 또는 대시보드 설정)
BLOGGER_BLOG_ID=1234567890123456789

# ── 네이버 DataLab (선택사항) ──────────
# https://developers.naver.com/apps 에서 애플리케이션 등록
# 없어도 Google Trends만으로 동작
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 봇 동작 설정 ────────────────────────
# 하루 생성 글 수 (애드센스 심사 중: 2~3, 승인 후: 3~5)
POSTS_PER_DAY=3

# 초안 저장 여부 (true: 검토 후 발행, false: 즉시 발행)
# 애드센스 심사 전에는 false 권장 (글이 실제로 쌓여야 승인됨)
PUBLISH_AS_DRAFT=false

# 글 업로드 간격 (초) - API 한도 방지
POST_DELAY_SECONDS=15

# 블로그 언어 (ko: 한국어, en: 영어)
BLOG_LANGUAGE=ko

# ── Google AdSense (선택사항) ───────────
# 게시자 ID: AdSense 대시보드 → 계정 → 게시자 ID
ADSENSE_CLIENT=ca-pub-2764893290310463
# 광고 단위 슬롯 ID (선택): 비워두면 자동 광고 형식 사용
ADSENSE_SLOT=

# ── 쿠팡파트너스 (선택사항) ─────────────
# https://partners.coupang.com → 마이페이지 → 오픈API 신청
# 없으면 쿠팡 상품 섹션 비활성화 (AdSense만 동작)
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
